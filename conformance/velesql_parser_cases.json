{
  "version": "2.2.0",
  "cases": [
    {
      "id": "P001",
      "query": "SELECT * FROM docs LIMIT 5",
      "should_parse": true
    },
    {
      "id": "P002",
      "query": "SELECT * FROM docs WHERE category = 'tech' AND MATCH (d:Doc)-[:REL]->(x) LIMIT 10",
      "should_parse": true
    },
    {
      "id": "P003",
      "query": "MATCH (d:Doc) RETURN d LIMIT 1",
      "should_parse": true
    },
    {
      "id": "P004",
      "query": "SELEC * FROM docs",
      "should_parse": false
    },
    {
      "id": "P005",
      "query": "SELECT * docs",
      "should_parse": false
    },
    {
      "id": "P006",
      "query": "SELECT * FROM docs AS d",
      "should_parse": true,
      "from_alias": ["d"]
    },
    {
      "id": "P007",
      "query": "SELECT d.name, t.tag FROM docs AS d JOIN tags AS t ON d.id = t.doc_id",
      "should_parse": true,
      "from_alias": ["d", "t"]
    },
    {
      "id": "P008",
      "query": "SELECT e.name, m.name FROM employees AS e JOIN employees AS m ON e.manager_id = m.id",
      "should_parse": true,
      "from_alias": ["e", "m"]
    },
    {
      "id": "P009",
      "query": "SELECT * FROM docs JOIN tags AS t ON docs.id = t.doc_id",
      "should_parse": true,
      "from_alias": ["t"]
    },
    {
      "id": "P010",
      "query": "SELECT e.name, m.name, d.name FROM employees AS e JOIN employees AS m ON e.manager_id = m.id JOIN employees AS d ON m.manager_id = d.id",
      "should_parse": true,
      "from_alias": ["e", "m", "d"]
    }
  ]
}
