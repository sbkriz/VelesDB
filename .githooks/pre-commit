#!/bin/bash
# =============================================================================
# VelesDB-Core Pre-commit Hook
# =============================================================================
# Vérifie la qualité du code avant chaque commit:
# - Formatage (rustfmt)
# - Linting (clippy)
# - Tests unitaires
# - Audit de sécurité
# =============================================================================

set -e

echo "🔍 VelesDB-Core Pre-commit checks..."

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Check if we have staged Rust files
mapfile -t STAGED_RS_FILES < <(git diff --cached --name-only --diff-filter=ACM | grep '\.rs$' || true)

if [ ${#STAGED_RS_FILES[@]} -eq 0 ]; then
    echo -e "${YELLOW}⚠️  No Rust files staged, skipping Rust checks${NC}"
else
    # 1. Check formatting
    echo -e "\n${YELLOW}📐 Checking formatting...${NC}"
    if ! cargo fmt --all -- --check; then
        echo -e "${RED}❌ Formatting check failed. Run 'cargo fmt --all' to fix.${NC}"
        exit 1
    fi
    echo -e "${GREEN}✅ Formatting OK${NC}"

    # 2. Run clippy (exclude velesdb-python due to PyO3 env issues)
    # Note: -W pedantic (warning) instead of -D (deny) to not block commits on style opinions
    # -D warnings still catches correctness issues
    echo -e "\n${YELLOW}📎 Running clippy...${NC}"
    # Note: Workspace lints in Cargo.toml control which pedantic lints are active.
    # Do NOT add -W clippy::pedantic here — it overrides workspace allow/warn config.
    if ! cargo clippy --workspace --exclude velesdb-python --lib --bins -- -D warnings; then
        echo -e "${RED}❌ Clippy found issues. Fix them before committing.${NC}"
        exit 1
    fi
    echo -e "${GREEN}✅ Clippy OK${NC}"

    echo -e "\n${YELLOW}🛡️  Running clippy undocumented unsafe blocks...${NC}"
    if ! cargo clippy -p velesdb-core --lib --bins -- -A warnings -D clippy::undocumented_unsafe_blocks; then
        echo -e "${RED}❌ Clippy undocumented unsafe blocks check failed.${NC}"
        exit 1
    fi
    echo -e "${GREEN}✅ Undocumented unsafe blocks check OK${NC}"

    # 3. Run tests (exclude velesdb-python due to PyO3 env issues)
    echo -e "\n${YELLOW}🧪 Running tests...${NC}"
    if ! cargo test --workspace --exclude velesdb-python --lib; then
        echo -e "${RED}❌ Tests failed. Fix them before committing.${NC}"
        exit 1
    fi
    echo -e "${GREEN}✅ Tests OK${NC}"

    # 4. Unsafe SAFETY template enforcement (changed Rust files)
    echo -e "\n${YELLOW}🛡️  Checking SAFETY comments for unsafe blocks...${NC}"
    if ! python3 scripts/verify_unsafe_safety_template.py --files "${STAGED_RS_FILES[@]}" --strict; then
        echo -e "${RED}❌ Unsafe SAFETY template check failed.${NC}"
        exit 1
    fi
    echo -e "${GREEN}✅ SAFETY comments OK${NC}"

    # 5. TODO/FIXME/HACK governance for production code
    echo -e "\n${YELLOW}🧭 Checking TODO/FIXME/HACK issue tags...${NC}"
    if ! python3 scripts/check-todo-annotations.py --files "${STAGED_RS_FILES[@]}"; then
        echo -e "${RED}❌ Orphan TODO/FIXME/HACK found in production code.${NC}"
        exit 1
    fi
    echo -e "${GREEN}✅ TODO/FIXME/HACK governance OK${NC}"
fi

# 6. Python integration checks (if Python files staged)
STAGED_PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

if [ -n "$STAGED_PY_FILES" ]; then
    echo -e "\n${YELLOW}🐍 Checking Python integrations...${NC}"
    
    # Check for dangerous hash() usage (exclude docstrings, comments, hashlib)
    DANGEROUS_HASH=$(echo "$STAGED_PY_FILES" | xargs grep -l "hash(" 2>/dev/null | xargs grep -n "hash(" 2>/dev/null | grep -v "hashlib" | grep -v "#.*hash" | grep -v "__hash__" | grep -v '"""' | grep -v "'''" | grep -v "Python's hash" | grep -v "hash()" || true)
    
    if [ -n "$DANGEROUS_HASH" ]; then
        echo -e "${RED}❌ Dangerous hash() usage detected in staged Python files:${NC}"
        echo "$DANGEROUS_HASH"
        echo -e "${YELLOW}   Python hash() is non-deterministic across processes.${NC}"
        echo -e "${YELLOW}   Use hashlib.sha256() for IDs/deduplication.${NC}"
        exit 1
    fi
    echo -e "${GREEN}✅ Python checks OK${NC}"
fi

# 7. Check for secrets (basic check)
echo -e "\n${YELLOW}🔐 Checking for potential secrets...${NC}"
if git diff --cached --diff-filter=ACM | grep -iE '(api_key|secret|password|token)\s*=\s*["\x27][^"\x27]+["\x27]' | grep -v '#' | grep -v '//'; then
    echo -e "${RED}❌ Potential secret detected in staged changes!${NC}"
    echo -e "${RED}   Please remove secrets before committing.${NC}"
    exit 1
fi
echo -e "${GREEN}✅ No secrets detected${NC}"

echo -e "\n${GREEN}🎉 All pre-commit checks passed!${NC}\n"
